VITE_API_BASE_URL=http://localhost:8000
# Optional override. If omitted, WS base is derived from VITE_API_BASE_URL.
# VITE_WS_BASE_URL=ws://localhost:8000

# Optional TURN/STUN config as JSON array for stricter NAT networks.
# Example:
# VITE_ICE_SERVERS_JSON=[{"urls":"stun:stun.l.google.com:19302"},{"urls":"turn:YOUR_TURN_HOST:3478","username":"user","credential":"pass"}]
